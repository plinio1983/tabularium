generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyCode {
  HM
  TS
  OTHER
}

enum PaymentStatus {
  DA_PAGARE
  COMPLETATO
  PAGATO_PARZIALMENTE
}

enum PaidBy {
  HERBAL_MARKET
  ALTRO_OPERATORE
}

enum InvoiceStatus {
  NONE
  YES
  NO
  OK
  KO
  NON_PREVISTA
  IN_ATTESA
  INVIATA_SDI
  CONTESTAZIONE
  RICEVUTA
}

enum WorkspaceRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String?
  googleId     String?   @unique
  googleEmailVerified Boolean @default(false)
  name         String?
  isActive     Boolean   @default(true)
  isSystemAdmin Boolean  @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  sessions        AuthSession[]
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  ownerId   Int
  owner     User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            WorkspaceMember[]
  sessions           AuthSession[]
  companies          Company[]
  expenseCategories  ExpenseCategory[]
  banks              Bank[]
  paymentMethods     PaymentMethod[]
  suppliers          Supplier[]
  recurringExpenses  RecurringExpense[]
  expenses           Expense[]
  monthlyRevenues    MonthlyRevenue[]
  incomes            Income[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  workspaceId Int
  userId      Int
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model AuthSession {
  id          Int       @id @default(autoincrement())
  tokenHash   String    @unique
  userId      Int
  workspaceId Int?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model Company {
  id        Int       @id @default(autoincrement())
  code      CompanyCode @unique
  name      String
  workspaceId Int?
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  expenses  Expense[]
  revenues  MonthlyRevenue[]
  createdAt DateTime @default(now())

  @@index([workspaceId])
}

model ExpenseCategory {
  id        Int       @id @default(autoincrement())
  code      String
  name      String
  icon      String?
  workspaceId Int?
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  expenses  Expense[]
  recurringExpenses RecurringExpense[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
}

model Bank {
  id        Int       @id @default(autoincrement())
  name      String
  isFallback Boolean @default(false)
  workspaceId Int?
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  expenses  Expense[]
  payments  ExpensePayment[]
  recurringExpenses RecurringExpense[]
  incomeCredits Income[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model PaymentMethod {
  id        Int       @id @default(autoincrement())
  name      String
  kind      String    @default("BOTH")
  isFallback Boolean  @default(false)
  workspaceId Int?
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  incomePayments Income[]
  expensePayments ExpensePayment[]
  recurringExpenses RecurringExpense[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([kind])
}

model Supplier {
  id             Int       @id @default(autoincrement())
  businessName   String
  email          String?
  phone          String?
  pec            String?
  taxCodeSdi     String?
  alias          String?
  internalNotes  String?
  workspaceId    Int?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  expenses       Expense[]
  recurringExpenses RecurringExpense[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([businessName])
  @@index([alias])
  @@index([workspaceId])
}

model RecurringExpense {
  id                   Int       @id @default(autoincrement())
  workspaceId          Int?
  workspace            Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  startDate            DateTime
  cadence              String
  dueDay               Int?
  dueMonth             Int?
  accrualType          String    @default("MANUALE")
  billingPeriodMode    String    @default("SAME_MONTH")
  billingMonth         Int?
  merchant             String
  supplierId           Int?
  supplier             Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  categoryId           Int?
  category             ExpenseCategory? @relation(fields: [categoryId], references: [id])
  description          String?
  amount               Decimal   @db.Decimal(12, 2)
  vatRate              Decimal   @db.Decimal(5, 2) @default(22)
  isDeclared           Boolean   @default(true)
  hasElectronicInvoice Boolean   @default(true)
  paymentChannel       String?
  paymentMethodId      Int?
  paymentMethod        PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  bankId               Int?
  bank                 Bank?     @relation(fields: [bankId], references: [id])
  notes                String?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  generatedExpenses    Expense[]
  @@index([workspaceId])
  @@index([startDate])
  @@index([supplierId])
  @@index([isActive])
  @@index([paymentMethodId])
}


model Expense {
  id                    Int       @id @default(autoincrement())
  workspaceId           Int?
  workspace             Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  receivedDate          DateTime?
  merchant              String
  supplierId            Int
  supplier              Supplier  @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  categoryId            Int?
  category              ExpenseCategory? @relation(fields: [categoryId], references: [id])
  description           String?
  amount                Decimal   @db.Decimal(12, 2)
  paymentDate           DateTime?
  dueDate               DateTime?
  vatRate               Decimal   @db.Decimal(5, 2) @default(22)
  channel               String?
  bankId                Int?      // Legacy denormalized first payment bank. Use ExpensePayment.bankId as source of truth.
  bank                  Bank?     @relation(fields: [bankId], references: [id])
  isComplete            Boolean   @default(false)
  isDeclared            Boolean   @default(true)
  hasElectronicInvoice  Boolean   @default(true)
  isRecurring          Boolean   @default(false)
  isAutomaticPayment   Boolean   @default(false)
  invoiceStatus         InvoiceStatus @default(IN_ATTESA)
  companyId             Int?
  company               Company?  @relation(fields: [companyId], references: [id])
  paidByCurrentAccount  Boolean   @default(false)
  month                 Int
  year                  Int
  notes                 String?

  paymentStatus         PaymentStatus @default(DA_PAGARE)
  paidAmount            Decimal   @db.Decimal(12, 2) @default(0)
  paidBy                PaidBy    @default(HERBAL_MARKET)
  invoiceDocumentPath   String?

  payments              ExpensePayment[]
  attachments           ExpenseAttachment[]

  recurringExpenseId    Int?
  recurringExpense      RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  recurringExpensePeriodKey String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([recurringExpenseId, recurringExpensePeriodKey])
  @@index([workspaceId])
  @@index([year, month])
  @@index([merchant])
}

model ExpensePayment {
  id          Int       @id @default(autoincrement())
  expenseId   Int
  expense     Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  paymentDate DateTime?
  channel     String?
  paymentMethodId Int?
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  bankId      Int?
  bank        Bank?     @relation(fields: [bankId], references: [id])
  amount      Decimal   @db.Decimal(12, 2)
  paidBy      PaidBy    @default(HERBAL_MARKET)
  createdAt   DateTime  @default(now())

  @@index([expenseId])
  @@index([paymentDate])
  @@index([paymentMethodId])
}

model ExpenseAttachment {
  id           Int       @id @default(autoincrement())
  expenseId    Int
  expense      Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  originalName String
  path         String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime  @default(now())

  @@index([expenseId])
}

model MonthlyRevenue {
  id              Int       @id @default(autoincrement())
  workspaceId     Int?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  companyId       Int
  company         Company   @relation(fields: [companyId], references: [id])
  month           Int
  year            Int
  webAmount       Decimal   @db.Decimal(12, 2) @default(0)
  shopAmount      Decimal   @db.Decimal(12, 2) @default(0)
  noInvoiceAmount Decimal   @db.Decimal(12, 2) @default(0)
  totalOrders     Int?
  inps            Decimal   @db.Decimal(12, 2) @default(0)
  accountant      Decimal   @db.Decimal(12, 2) @default(0)
  tari            Decimal   @db.Decimal(12, 2) @default(0)
  taxRate         Decimal   @db.Decimal(5, 2) @default(28)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([companyId, year, month])
  @@index([workspaceId])
  @@index([year, month])
}


model Income {
  id              Int       @id @default(autoincrement())
  workspaceId     Int?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  salesChannel    String
  saleCategory    String    @default("B2C")
  description     String?
  amount          Decimal   @db.Decimal(12, 2)
  paymentMethod   String
  paymentMethodId Int?
  paymentMethodRef PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  creditChannel   String
  creditBankId    Int?
  creditBank      Bank?     @relation(fields: [creditBankId], references: [id])
  creditDate      DateTime
  isCredited      Boolean   @default(true)
  billingMonth    Int       @default(1)
  billingYear     Int       @default(2026)
  isFiscal        Boolean   @default(true)
  invoiceStatus   String?
  vatRate         Decimal   @db.Decimal(5, 2) @default(22)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([workspaceId])
  @@index([creditDate])
  @@index([billingYear, billingMonth])
  @@index([salesChannel])
  @@index([saleCategory])
  @@index([isFiscal])
  @@index([paymentMethodId])
  @@index([creditBankId])
}
